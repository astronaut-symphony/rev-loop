# Vercel Blob token — auto-set when you add Blob integration in Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# Secret untuk signing session cookie. Generate dengan: openssl rand -base64 32
SESSION_SECRET=replace-with-random-32-chars-min

# 3 user accounts. Format: username:password,username:password,...
# Contoh: alice:rahasia1,bob:rahasia2,charlie:rahasia3
USERS=alice:password1,bob:password2,charlie:password3
